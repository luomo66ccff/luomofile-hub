APP_NAME=LuomoFile Hub
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8791
APP_BASE_URL=http://localhost:8791
APP_VERSION=0.1.0
LUOMOFILE_INTERNAL_TOKEN=

DATABASE_PATH=/app/data/luomofile.db
SESSION_SECRET=
PUBLIC_LINK_SECRET=

ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_SSL=true
EMAIL_VERIFICATION_TTL_SECONDS=86400

MAX_UPLOAD_BYTES=524288000
MAX_IMAGE_BYTES=52428800
MAX_TEMP_BYTES=209715200
ALLOW_ANONYMOUS_UPLOAD=false
ANONYMOUS_MAX_UPLOAD_BYTES=10485760
DEFAULT_TEMP_TTL_SECONDS=86400

R2_ENABLED=false
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
R2_MAX_CAPACITY_BYTES=10737418240

COS_ENABLED=false
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=
COS_BUCKET=
COS_PUBLIC_BASE_URL=
COS_MAX_CAPACITY_BYTES=53687091200
COS_MOUNT_PATH=/mnt/cos
COS_HOST_MOUNT_PATH=./data/cos
COS_SV_ENABLED=false
COS_SV_PUBLIC_BASE_URL=
COS_SV_MAX_CAPACITY_BYTES=53687091200
COS_SV_MOUNT_PATH=/mnt/cos_sv
COS_SV_HOST_MOUNT_PATH=./data/cos-sv

LOCAL_TEMP_ENABLED=true
LOCAL_TEMP_PATH=/app/data/tmp
LOCAL_TEMP_MAX_CAPACITY_BYTES=1073741824

CLEANUP_INTERVAL_SECONDS=300
STORAGE_REFRESH_INTERVAL_SECONDS=600
